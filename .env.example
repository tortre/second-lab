# Required only for live review and GPT coaching. The cached LeafLens demo works without it.
OPENAI_API_KEY=

# Optional explicit aliases; defaults should remain pinned in server code and recorded in receipts.
OPENAI_REVIEW_MODEL=gpt-5.6
OPENAI_COACH_MODEL=gpt-5.6
MULTI_AGENT_ENABLED=true

# Protects hosted live review. Use a long random value for each; never reuse an API key here.
JUDGE_ACCESS_CODE=
SESSION_SIGNING_SECRET=

# Public production origin used by hosted origin validation, for example https://second-lab.example.com.
ALLOWED_ORIGIN=

# Live evaluation reporting only. Copy current official per-million-token rates
# immediately before the run and record the dated pricing URL.
EVAL_INPUT_COST_PER_MILLION=
EVAL_OUTPUT_COST_PER_MILLION=
EVAL_PRICING_SOURCE=
EVAL_BASE_URL=
EVAL_ACCESS_CODE=
# Alternative for CI or a previously authenticated operator session.
EVAL_ACCESS_COOKIE=
